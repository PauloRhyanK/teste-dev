{
  "name": "quansa-teste",
  "version": "1.0.0",
  "private": true,
  "description": "Processamento de pagamentos via Stark Bank Sandbox",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @quansa/api",
    "dev:web": "npm run dev -w @quansa/web",
    "build": "npm run build -w @quansa/shared-types && npm run build -w @quansa/api && npm run build -w @quansa/web",
    "start": "npm run start -w @quansa/api",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "npm run test -w @quansa/api",
    "starkbank:check": "npm run starkbank:check -w @quansa/api"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
